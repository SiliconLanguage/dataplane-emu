[global]
ioengine=spdk
thread=1
group_reporting=1
direct=1
verify=0
time_based=1
ramp_time=2
runtime=60

[arm-neoverse-nvme-stress]
# 4K Random Mixed I/O to showcase Neoverse-N2 throughput
bs=4k
rw=randrw
rwmixread=70
iodepth=256
# This targets the alias we create in the tmux launch
filename=Nvme0n1

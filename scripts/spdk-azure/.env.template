# --- Azure Infrastructure Secrets ---
# Found in Azure Portal > Subscriptions
AZ_SUBSCRIPTION_ID="your_subscription_id_here"

# Your specific Resource Group and VM Name
AZ_RESOURCE_GROUP="your_resource_group_here"
AZ_VM_NAME="your_vm_name_here"
AZ_LOCATION="your_region_here"
AZ_USER="your_admin_username_here"

# --- External Integration (Optional) ---
# If you use the start-cobalt.ps1 script with Cloudflare
CF_API_TOKEN="your_cloudflare_token_here"
CF_ZONE_ID="your_cloudflare_zone_id_here"
GITHUB_TOKEN="ghp_your_github_token_here"
